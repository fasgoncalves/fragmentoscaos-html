  <div style="border-top:1px solid #ffcc78; padding-top:18px; color:#ffcca0; margin-top:30px;">
    <p style="margin:0 0 10px 0;">
      <strong><a href="https://www.fragmentoscaos.eu/sobre-francisco-goncalves/" target="_blank" rel="noopener" style="color:#ffcc66 !important;">Francisco Gonçalves</a></strong> — publicado em Fragmentos do Caos
    </p>
    <p style="margin:0;">
