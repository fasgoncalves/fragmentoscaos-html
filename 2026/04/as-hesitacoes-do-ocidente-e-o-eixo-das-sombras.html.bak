            font:15px/1.5 ui-sans-serif,system-ui,-apple-system,'Segoe UI',Roboto,Helvetica,Arial;
            background:linear-gradient(135deg,#111627,#1e244a);color:#ffffff;border-radius:12px;
            text-align:center;box-shadow:0 3px 8px rgba(0,0,0,.3);">
  <span style="font-weight:700;margin-right:8px;">🌌 Fragmentos do Caos:</span>
  <a href="https://fasgoncalves.github.io/fragmentoscaos-html" target="_blank" rel="noopener"
     style="color:#90caf9;text-decoration:none;margin:0 8px;border-bottom:1px dotted rgba(144,202,249,.6);">
