        <div style="background:#0b0b0b; color:#e8eef4; font-family:Georgia, serif; line-height:2.2; padding:10px; text-align:left;">

<div style="display:none;">
  <div itemscope itemtype="https://schema.org/NewsArticle">
    <meta itemprop="headline" content="Portugal precisa de imprensa, não de espuma">
    <meta itemprop="datePublished" content="2026-04-24">
    <meta itemprop="dateModified" content="2026-04-24">
    <meta itemprop="description" content="Uma reflexão sobre a necessidade de uma imprensa credível em Portugal, capaz de abandonar o ruído da agenda política menor e de abrir espaço à sociedade civil, à análise séria e à reconstrução moral da democracia.">
    <meta itemprop="author" content="Francisco Gonçalves">
    <meta itemprop="author" content="Augustus Veritas">
    <meta itemprop="publisher" content="Fragmentos do Caos">
    <meta itemprop="image" content="http://www.fragmentoscaos.eu/wp-content/uploads/2026/04/8fd32e54-d37b-4dfc-919e-3a1576654f2f.png">
