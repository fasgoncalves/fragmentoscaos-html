    <article class="post">
      <h1 class="post-title">Portugal e a Tragédia Cómica da Ignorância sobre o Open Source</h1>
      <p class="meta">Publicado em 2026-04-20 21:20:41</p>
      <figure class="post-thumb"><img src="https://fasgoncalves.github.io/fragmentoscaos-img/imagens/file_0000000070d471fda50fd1cac6d19eb8.jpg" alt=""></figure>
      <div class="post-content">
        <div style="background:#0b0b0b; color:#e8eef4; font-family:Georgia, serif; line-height:2.2; padding:10px; text-align:left;">

<div style="display:none;">
  <div itemscope itemtype="https://schema.org/NewsArticle">
    <meta itemprop="headline" content="Portugal e a Tragédia Cómica da Ignorância sobre o Open Source">
    <meta itemprop="datePublished" content="2026-04-20">
    <meta itemprop="dateModified" content="2026-04-20">
    <meta itemprop="description" content="Uma crónica crítica sobre a persistente ignorância portuguesa em relação ao software open source, apesar das vantagens económicas, tecnológicas e estratégicas evidentes.">
    <meta itemprop="author" content="Francisco Gonçalves">
    <meta itemprop="author" content="Augustus Veritas">
    <meta itemprop="publisher" content="Fragmentos do Caos">
    <meta itemprop="image" content="http://www.fragmentoscaos.eu/wp-content/uploads/2026/04/file_0000000070d471fda50fd1cac6d19eb8.png">
