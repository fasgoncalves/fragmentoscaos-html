      animation: brilho-suave 4s ease-in-out infinite;
    }

    .content-wrapper {
      text-align: center;
    }

    main {
      max-width: 1200px;
      margin: 0 auto;
      padding: 40px 20px;
      padding-top: 130px; 
    }

    a {
      color: #ffcc66;
      text-decoration: none;
    }

    a:hover {
