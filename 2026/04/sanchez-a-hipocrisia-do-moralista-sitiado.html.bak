      <h1 class="post-title">Sánchez, a hipocrisia do moralista sitiado</h1>
      <p class="meta">Publicado em 2026-04-18 20:19:01</p>
      <figure class="post-thumb"><img src="https://fasgoncalves.github.io/fragmentoscaos-img/imagens/file_00000000633872469d2bff13d215d5dd.jpg" alt=""></figure>
      <div class="post-content">
        <div style="background:#0b0b0b; color:#e8eef4; font-family:Georgia,serif; line-height:2.2; padding:10px; text-align:left;">

<div style="display:none;">
  <div itemscope itemtype="https://schema.org/NewsArticle">
    <meta itemprop="headline" content="Sánchez, a hipocrisia do moralista sitiado" />
    <meta itemprop="datePublished" content="2026-04-18" />
    <meta itemprop="dateModified" content="2026-04-18" />
    <meta itemprop="description" content="Uma análise crítica à contradição entre a projecção internacional de Pedro Sánchez como defensor do multilateralismo e os casos que cercam o seu núcleo político e familiar." />
    <meta itemprop="author" content="Francisco Gonçalves" />
    <meta itemprop="author" content="Augustus Veritas" />
    <meta itemprop="mainEntityOfPage" content="https://www.fragmentoscaos.eu/" />
    <meta itemprop="image" content="http://www.fragmentoscaos.eu/wp-content/uploads/2026/04/file_00000000633872469d2bff13d215d5dd.png" />
    <div itemprop="publisher" itemscope itemtype="https://schema.org/Organization">
