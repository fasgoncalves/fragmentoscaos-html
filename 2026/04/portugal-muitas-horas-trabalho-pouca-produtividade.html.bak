    <meta itemprop="headline" content="Muitas Horas, Pouco Valor">
    <meta itemprop="datePublished" content="2026-04-02">
    <meta itemprop="dateModified" content="2026-04-02">
    <meta itemprop="description" content="Crónica sobre o paradoxo português de longas jornadas de trabalho e fraca produtividade, revelando o atraso de muitas empresas que ainda medem presença em vez de resultados.">
