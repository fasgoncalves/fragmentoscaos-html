      <p class="meta">Publicado em 2026-04-24 13:43:00</p>
      <figure class="post-thumb"><img src="https://fasgoncalves.github.io/fragmentoscaos-img/imagens/screenshot_20260423_195152.jpg" alt=""></figure>
      <div class="post-content">
        <div style="background:#0b0b0b;color:#e8eef4;font-family:Georgia,serif;line-height:2.2;padding:10px;text-align:left;">

<div style="display:none;">
  <div itemscope itemtype="https://schema.org/NewsArticle">
    <meta itemprop="headline" content="Rui Pinto, Saco Azul e a inversão moral da justiça portuguesa" />
    <meta itemprop="datePublished" content="2026-04-23" />
    <meta itemprop="dateModified" content="2026-04-23" />
    <meta itemprop="description" content="Uma reflexão crítica sobre o contraste entre a absolvição no processo Saco Azul e o percurso judicial de Rui Pinto, e sobre a erosão moral da confiança na justiça portuguesa." />
    <meta itemprop="author" content="Francisco Gonçalves" />
    <meta itemprop="author" content="Augustus Veritas" />
    <meta itemprop="publisher" content="Fragmentos do Caos" />
