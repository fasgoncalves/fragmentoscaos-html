<style>
:root {
  --bg: #fafafa;
  --fg: #141414;
  --muted: #6b7280;
  --link: #1a56db;
  --card: #ffffff;
  --ring: rgba(26,86,219,0.15);
  --maxw: 800px;
}
* { box-sizing: border-box; }
html, body { margin: 0; padding: 0; background: var(--bg); color: var(--fg); }
body { font: 16.5px/1.75 "Inter", system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif; }

.wrap {
  max-width: var(--maxw);
  margin: 0 auto;
  padding: 28px 28px 80px; /* margem extra à esquerda e direita */
}
.post {
  background: var(--card);
  border-radius: 14px;
  padding: 24px;
  box-shadow: 0 8px 24px rgba(0,0,0,0.06);
  border: 1px solid rgba(0,0,0,0.05);
  text-align: left; /* alinha conteúdo à esquerda */
}

/* Título/meta/thumbnail centrados */
.post-title, .meta, .post-thumb { text-align: center; }

.post-title {
  font-family: "Merriweather", Georgia, "Times New Roman", serif;
  font-weight: 700;
  letter-spacing: 0.2px;
  font-size: clamp(1.8rem, 2.4vw + 1rem, 2.6rem);
  line-height: 1.15;
  margin: 0 0 8px 0;
}
.meta { margin: 0 0 18px; color: var(--muted); font-size: 0.95rem; }

.post-thumb, .post-content figure { margin: 18px auto; text-align: center; }
.post-thumb img { max-width: 100%; height: auto; display: block; margin: 0 auto; border-radius: 12px; box-shadow: 0 6px 18px rgba(0,0,0,0.09); }

.post-content {
  font-size: 1.08rem;
  letter-spacing: 0.01em;
  text-align: left; /* texto do artigo à esquerda */
}

/* Corrige alinhamentos vindos do WP que forçam centrado */
.post-content .has-text-align-center:not(figure):not(.wp-block-image):not(img) { text-align: left !important; }
.post-content p[style*="text-align:center"],
.post-content h1[style*="text-align:center"],
.post-content h2[style*="text-align:center"],
.post-content h3[style*="text-align:center"],
.post-content h4[style*="text-align:center"],
.post-content h5[style*="text-align:center"],
.post-content h6[style*="text-align:center"] { text-align: left !important; }

.post-content img,
.post-content .wp-block-image img,
.post-content figure img {
  max-width: 100%;
  height: auto;
  display: block;
  margin: 16px auto; /* imagens continuam centradas visualmente */
  border-radius: 10px;
  box-shadow: 0 4px 14px rgba(0,0,0,0.08);
}

/* --- Quebras e scroll horizontal quando necessário --- */
.post, .post-content {
  overflow-wrap: anywhere;
  word-break: break-word;
}

.post-content pre,
.post-content .wp-block-code,
.post-content .wp-block-preformatted {
  white-space: pre; /* mantém formatação de código */
  overflow-x: auto; /* scroll horizontal quando necessário */
  -webkit-overflow-scrolling: touch; /* scroll fluido no iOS */
  max-width: 100%;
}

.post-content code {
  white-space: break-spaces; /* inline code não estoura para fora */
}

.post-content table,
.post-content .wp-block-table {
  display: block; /* permite overflow-x */
  width: 100%;
  overflow-x: auto; /* scroll horizontal quando necessário */
  -webkit-overflow-scrolling: touch;
}

.post-content .wp-block-embed,
.post-content iframe {
  max-width: 100%;
  display: block;
  overflow: hidden; /* evita estoiro do container */
}

blockquote {
  border-left: 4px solid var(--ring);
  padding: 0.1em 1em;
  margin: 1.2em 0;
  color: #374151;
  background: rgba(0,0,0,0.02);
  border-radius: 6px;
}

/* Mais largura útil no telemóvel */
@media (max-width: 640px) {
  .wrap { 
    padding: 18px 10px 64px; /* menos padding lateral (40px → 10px) = mais largura útil */
  }
  .post {
    padding: 12px; /* era 28px; mais área para o texto */
  }
  .post-content {
    font-size: 1.06rem; /* ligeiro ajuste de leitura */
  }
}

@media (max-width: 640px) {
  /* Faixas com scroll para conteúdo largo no mobile */
  .post-content pre,
  .post-content .wp-block-code,
  .post-content table,
  .post-content .wp-block-table {
    margin-left: -6px;  /* encosta à margem para ganhar largura útil */
    margin-right: -6px;
    padding-left: 6px;
    padding-right: 6px;
  }
}

@media (min-width: 1280px) {
  :root { --maxw: 1000px; }
}

/* 📱 Ajuste de margens para telemóveis - modo imersivo */
@media (max-width: 1000px) {
  main, .site-content, .post, .entry-content {
    max-width: 100%;
    padding-left: 5px !important;   /* margem esquerda reduzida */
    padding-right: 5px !important;  /* margem direita reduzida */
    padding-top: 22px;              /* espaço no topo */
    padding-bottom: 22px;           /* espaço no fundo */
  }
}

@media (prefers-color-scheme: dark) {
  :root {
    --bg: #0e0f12; --fg:#e8e8ea; --muted:#9aa2ad; --card:#12141a; --link:#7aa2ff; --ring: rgba(122,162,255,0.25);
  }
  .post { border-color: rgba(255,255,255,0.06); box-shadow: 0 10px 28px rgba(0,0,0,0.35); }
  blockquote { color:#cfd6df; background: rgba(255,255,255,0.03); }
}

/* Tables */

 .table-container {
    overflow-x: auto;
    margin: 20px 0;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    background-color: #111;
    min-width: 800px;
  }

  th, td {
    border: 1px solid #444;
    padding: 8px;
    text-align: center;
  }

  th {
    color: #ffcc66 !important;
    background-color: #111;
    font-weight: bold;
  }

  tr:nth-child(even) {
    background-color: #181818;
  }

  tr:hover {
    background-color: #222;
  }
/* Espaçamento generoso entre parágrafos */
p {
  margin-top: 1.2em !important;
  margin-bottom: 1.4em !important;
  line-height: 1.9;
  text-align: justify;
}

/* Opcional: ligeiro recuo na primeira linha de cada parágrafo */
p + p {
  text-indent: 1.5em;
}


/* --- Animação de brilho partilhada --- */
    @keyframes brilho-suave {
      0% { opacity: 0.4; text-shadow: 0 0 4px #ffcc66; }
      50% { opacity: 1; text-shadow: 0 0 14px #ffcc66; }
      100% { opacity: 0.4; text-shadow: 0 0 4px #ffcc66; }
    }

    /* --- Banner de topo --- */
    .banner-fc {
