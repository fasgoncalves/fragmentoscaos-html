<div style="display:none;">
  <div itemscope itemtype="https://schema.org/NewsArticle">
    <meta itemprop="headline" content="Todos Iguais Perante a Lei? A Comédia Constitucional Portuguesa" />
    <meta itemprop="datePublished" content="2026-04-04" />
    <meta itemprop="dateModified" content="2026-04-04" />
    <meta itemprop="description" content="Um artigo crítico e irónico sobre o actual ruído em torno da revisão constitucional em Portugal e a escandalosa distância entre o artigo 13.º da Constituição e a realidade vivida pelos portugueses." />
    <meta itemprop="author" content="Francisco Gonçalves" />
    <meta itemprop="author" content="Augustus Veritas" />
    <meta itemprop="publisher" content="Fragmentos do Caos" />
    <meta itemprop="image" content="http://www.fragmentoscaos.eu/wp-content/uploads/2026/04/file_000000008d08720ab0a62ea99ef919ec.png" />
