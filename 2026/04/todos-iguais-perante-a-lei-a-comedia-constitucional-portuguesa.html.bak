    }

    .content-wrapper {
      text-align: center;
    }

    main {
      max-width: 1200px;
      margin: 0 auto;
      padding: 40px 20px;
      padding-top: 130px; 
    }

    a {
      color: #ffcc66;
      text-decoration: none;
    }

    a:hover {
      text-decoration: underline;
      color: #ffee99;
    }

    /* --- Rodapé --- */
    .footer-fc {
      position: fixed;
      bottom: 0;
      left: 0;
