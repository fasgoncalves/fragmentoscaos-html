      <h1 class="post-title">Portugal  : Deputados do Povo Que o Povo Não Escolhe</h1>
      <p class="meta">Publicado em 2026-04-02 09:53:51</p>
      <figure class="post-thumb"><img src="https://fasgoncalves.github.io/fragmentoscaos-img/imagens/file_000000001dc871f58f16471cb9d45c99.jpg" alt=""></figure>
      <div class="post-content">
        <div style="background:#0b0b0b; color:#e8eef4; font-family:Georgia, serif; line-height:2.2; padding:10px; text-align:left;">

<div style="display:none;">
  <div itemscope itemtype="https://schema.org/NewsArticle">
    <meta itemprop="headline" content="Os Deputados do Povo Que o Povo Não Escolhe">
    <meta itemprop="datePublished" content="2026-04-02">
    <meta itemprop="dateModified" content="2026-04-02">
    <meta itemprop="description" content="Crónica sobre a ficção respeitável da representação parlamentar em Portugal, num sistema em que o eleitor vota listas fechadas previamente definidas pelos aparelhos partidários.">
    <meta itemprop="author" content="Francisco Gonçalves">
    <meta itemprop="author" content="Augustus Veritas">
    <meta itemprop="mainEntityOfPage" content="https://www.fragmentoscaos.eu/">
    <meta itemprop="image" content="http://www.fragmentoscaos.eu/wp-content/uploads/2026/04/file_000000001dc871f58f16471cb9d45c99.png">
    <div itemprop="publisher" itemscope itemtype="https://schema.org/Organization">
      <meta itemprop="name" content="Fragmentos do Caos">
      <div itemprop="logo" itemscope itemtype="https://schema.org/ImageObject">
