        <div style="background:#0b0b0b; color:#e8eef4; font-family:Georgia,serif; line-height:2.2; padding:10px; text-align:left;">
<div itemscope itemtype="https://schema.org/NewsArticle" style="display:none;">
    <meta itemprop="headline" content="Agostinho da Silva e as Três Liberdades Sem as Quais a Democracia é Apenas um Ritual" />
<meta itemprop="description" content="Uma reflexão sobre a liberdade de cultura, a liberdade de organização social e a liberdade económica como pilares de uma democracia viva." />
<meta itemprop="datePublished" content="2026-05-09T18:00:00+01:00" />
<meta itemprop="dateModified" content="2026-05-09T18:00:00+01:00" />
<meta itemprop="author" content="Francisco Gonçalves" />
<meta itemprop="publisher" content="Fragmentos do Caos" />
