    <article class="post">
      <h1 class="post-title">O Eixo da Conveniência Autoritária: China, Irão e a Nova Geometria do Medo</h1>
      <p class="meta">Publicado em 2026-05-08 15:33:07</p>
      <figure class="post-thumb"><img src="https://fasgoncalves.github.io/fragmentoscaos-img/imagens/file_00000000e58071f49870360bf251e2cc.jpg" alt=""></figure>
      <div class="post-content">
        <div style="background:#0b0b0b; color:#e8eef4; font-family:Georgia,serif; line-height:2.2; padding:10px; text-align:left;">

  <div itemscope itemtype="https://schema.org/NewsArticle" style="display:none;">
    <meta itemprop="headline" content="O Eixo da Conveniência Autoritária: China, Irão e a Nova Geometria do Medo">
    <meta itemprop="datePublished" content="2026-05-01">
    <meta itemprop="dateModified" content="2026-05-01">
    <meta itemprop="description" content="Uma análise crítica sobre a crescente convergência estratégica entre China, Rússia, Irão e Coreia do Norte, e sobre o papel paciente e calculista de Pequim na erosão da ordem liberal.">
    <span itemprop="author" itemscope itemtype="https://schema.org/Person">
      <meta itemprop="name" content="Francisco Gonçalves">
    </span>
    <span itemprop="publisher" itemscope itemtype="https://schema.org/Organization">
