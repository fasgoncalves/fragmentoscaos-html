  <meta itemprop="datePublished" content="2026-03-06">
  <meta itemprop="dateModified" content="2026-03-06">
  <meta itemprop="description" content="Crónica editorial sobre a incapacidade de reforma da União Europeia, a fragilidade moral e intelectual das suas lideranças e a dependência estratégica que acabou por dar razão parcial a Trump.">
  <meta itemprop="inLanguage" content="pt-PT">
  <div itemprop="author" itemscope itemtype="https://schema.org/Person">
