    </div>
  </div>
  <div itemprop="image" itemscope itemtype="https://schema.org/ImageObject">
    <meta itemprop="url" content="http://www.fragmentoscaos.eu/wp-content/uploads/2026/03/file_00000000205c7243b1ad0e8acbf40201.png">
  </div>
