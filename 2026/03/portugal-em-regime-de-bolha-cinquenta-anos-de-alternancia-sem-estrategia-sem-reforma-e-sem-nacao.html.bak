      <figure class="post-thumb"><img src="https://fasgoncalves.github.io/fragmentoscaos-img/imagens/file_00000000d59c724398be25616d5a6040.jpg" alt=""></figure>
      <div class="post-content">
        <div style="background:#0b0b0b; color:#e8eef4; font-family:Georgia, serif; line-height:2.2; padding:10px; text-align:left;">

<div style="display:none;">
  <div itemscope itemtype="https://schema.org/NewsArticle">
    <meta itemprop="headline" content="Portugal em Regime de Bolha: Cinquenta Anos de Alternância sem Estratégia, sem Reforma e sem Nação">
    <meta itemprop="datePublished" content="2026-03-28">
    <meta itemprop="dateModified" content="2026-03-28">
    <meta itemprop="description" content="Uma reflexão crítica sobre a opacidade dos partidos do regime, a incapacidade de reformar o Estado, a debilidade da economia portuguesa e o afastamento crescente entre o sistema político e a sociedade civil.">
    <meta itemprop="author" content="Francisco Gonçalves">
    <meta itemprop="author" content="Augustus">
