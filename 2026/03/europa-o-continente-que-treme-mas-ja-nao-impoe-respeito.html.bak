        <div style="background:#0b0b0b; color:#e8eef4; font-family:Georgia, serif; line-height:2.2; padding:10px; text-align:left;">

  <div style="display:none;">
    <div itemscope itemtype="https://schema.org/NewsArticle">
      <meta itemprop="headline" content="Europa: O Continente Que Treme, Mas Já Não Impõe Respeito">
      <meta itemprop="datePublished" content="2026-03-17">
      <meta itemprop="dateModified" content="2026-03-17">
      <meta itemprop="description" content="Crónica editorial sobre a posição europeia perante a guerra contra o Irão, a impotência estratégica da União Europeia e a distância entre discurso moral e capacidade geopolítica.">
      <meta itemprop="author" content="Francisco Gonçalves">
      <meta itemprop="author" content="Augustus Veritas">
      <meta itemprop="publisher" content="Fragmentos do Caos">
      <div itemprop="publisher" itemscope itemtype="https://schema.org/Organization">
