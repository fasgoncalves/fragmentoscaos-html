    <article class="post">
      <h1 class="post-title">Pedro Sánchez e o teatro moral da Europa</h1>
      <p class="meta">Publicado em 2026-03-06 23:16:40</p>
      <figure class="post-thumb"><img src="https://fasgoncalves.github.io/fragmentoscaos-img/imagens/file_00000000b81c720a87231ef7a2220c5b.jpg" alt=""></figure>
      <div class="post-content">
        <div style="background:#0b0b0b; color:#e8eef4; font-family:Georgia,serif; line-height:2.2; padding:10px; text-align:left;">

<div style="display:none;" itemscope itemtype="https://schema.org/NewsArticle">
  <meta itemprop="headline" content="Pedro Sánchez e o teatro moral da Europa">
  <meta itemprop="datePublished" content="2026-03-06">
  <meta itemprop="dateModified" content="2026-03-06">
  <meta itemprop="description" content="Crónica editorial sobre a dissociação entre o desgaste político interno de Pedro Sánchez e a sua projecção como figura europeia.">
  <meta itemprop="inLanguage" content="pt-PT">
  <div itemprop="author" itemscope itemtype="https://schema.org/Person">
    <meta itemprop="name" content="Francisco Gonçalves">
  </div>
  <div itemprop="author" itemscope itemtype="https://schema.org/Person">
    <meta itemprop="name" content="Augustus">
  </div>
  <div itemprop="publisher" itemscope itemtype="https://schema.org/Organization">
