    </div>
  </div>
  <div itemprop="image" itemscope itemtype="https://schema.org/ImageObject">
    <meta itemprop="url" content="http://www.fragmentoscaos.eu/wp-content/uploads/2026/03/file_00000000b81c720a87231ef7a2220c5b.png">
  </div>
