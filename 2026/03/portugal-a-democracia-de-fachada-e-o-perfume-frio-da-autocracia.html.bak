      <h1 class="post-title">Portugal: a democracia de fachada e o perfume frio da autocracia</h1>
      <p class="meta">Publicado em 2026-03-08 17:04:14</p>
      <figure class="post-thumb"><img src="https://fasgoncalves.github.io/fragmentoscaos-img/imagens/file_0000000000a4720a96a1407fc4c82d34.jpg" alt=""></figure>
      <div class="post-content">
        <div style="background:#0b0b0b; color:#e8eef4; font-family:Georgia, serif; line-height:2.2; padding:10px; text-align:left;">

  <div itemscope itemtype="https://schema.org/NewsArticle" style="display:none;">
    <meta itemprop="headline" content="Portugal: a democracia de fachada e o perfume frio da autocracia">
    <meta itemprop="datePublished" content="2026-03-08">
    <meta itemprop="dateModified" content="2026-03-08">
    <meta itemprop="description" content="Uma reflexão crítica sobre o aviso do Presidente do Tribunal Constitucional, os limites materiais da revisão constitucional e a erosão silenciosa da substância democrática em Portugal.">
    <meta itemprop="inLanguage" content="pt-PT">
    <div itemprop="author" itemscope itemtype="https://schema.org/Person">
      <meta itemprop="name" content="Francisco Gonçalves">
