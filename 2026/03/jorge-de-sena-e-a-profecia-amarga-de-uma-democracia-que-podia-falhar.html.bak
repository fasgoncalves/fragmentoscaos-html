  <meta itemprop="datePublished" content="2026-03-11">
  <meta itemprop="dateModified" content="2026-03-11">
  <meta itemprop="description" content="Uma crónica sobre a lucidez de Jorge de Sena perante os riscos da democracia portuguesa e um balanço crítico de cinquenta anos de regime democrático em Portugal.">
  <meta itemprop="author" content="Francisco Gonçalves & Augustus">
  <meta itemprop="mainEntityOfPage" content="https://www.fragmentoscaos.eu/">
