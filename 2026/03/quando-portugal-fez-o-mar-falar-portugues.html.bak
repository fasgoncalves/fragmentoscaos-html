      <h1 class="post-title">Quando Portugal Fez o Mar Falar Português</h1>
      <p class="meta">Publicado em 2026-03-27 00:43:01</p>
      <figure class="post-thumb"><img src="https://fasgoncalves.github.io/fragmentoscaos-img/imagens/file_00000000f39c7243bc3ef03325b6a74b.jpg" alt=""></figure>
      <div class="post-content">
        <div style="background:#0b0b0b; color:#e8eef4; font-family:Georgia,serif; line-height:2.2; padding:10px; text-align:left;">

<div style="display:none;" itemscope itemtype="https://schema.org/NewsArticle">
  <meta itemprop="headline" content="Quando Portugal Fez o Mar Falar Português" />
  <meta itemprop="datePublished" content="2026-03-27" />
  <meta itemprop="dateModified" content="2026-03-27" />
  <meta itemprop="description" content="Crónica histórica sobre a supremacia marítima portuguesa na viragem para 1500, a ciência náutica, a artilharia embarcada e a prudência estratégica de Castela perante o poder naval português." />
  <meta itemprop="inLanguage" content="pt-PT" />
  <div itemprop="author" itemscope itemtype="https://schema.org/Person">
    <meta itemprop="name" content="Francisco Gonçalves" />
  </div>
