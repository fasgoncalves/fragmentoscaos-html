      border-bottom: 2px solid #ffcc66;
      z-index: 9999;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.9);
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0px;
    }

    .banner-fc img {
