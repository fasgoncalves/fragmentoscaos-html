        <div style="background:#0b0b0b; color:#e8eef4; font-family:Georgia, serif; line-height:2.2; padding:10px; text-align:left;">

<div style="display:none;" itemscope itemtype="https://schema.org/NewsArticle">
  <meta itemprop="headline" content="O País Que Perdoa Sempre ao Mesmo Rosto">
  <meta itemprop="datePublished" content="2026-03-15">
  <meta itemprop="dateModified" content="2026-03-15">
  <meta itemprop="description" content="Crónica crítica sobre a indulgência mediática e popular em torno da presidência de Marcelo Rebelo de Sousa, apesar das polémicas e do desgaste institucional.">
  <meta itemprop="author" content="Francisco Gonçalves">
  <meta itemprop="author" content="Augustus">
  <div itemprop="publisher" itemscope itemtype="https://schema.org/Organization">
