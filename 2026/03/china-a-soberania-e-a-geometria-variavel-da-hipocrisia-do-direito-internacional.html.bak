      left: 0;
      width: 100%;
      background-color: #000;
      color: #ffcc66;
      text-align: center;
      padding: 10px 0 5px;
      font-family: 'Segoe UI', sans-serif;
      border-bottom: 2px solid #ffcc66;
      z-index: 9999;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.9);
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0px;
    }

    .banner-fc img {
      height: 55px;
      width: auto;
      vertical-align: middle;
    }

    .banner-fc h1 {
      font-size: 26px;
      font-weight: 600;
      letter-spacing: 1px;
      margin: 0;
    }

    .banner-fc p {
      font-size: 15px;
      font-style: italic;
      color: #ffdd88;
      margin-top: 4px;
      animation: brilho-suave 4s ease-in-out infinite;
    }

    .content-wrapper {
      text-align: center;
    }

    main {
      max-width: 1200px;
      margin: 0 auto;
      padding: 40px 20px;
      padding-top: 130px; 
    }

    a {
      color: #ffcc66;
      text-decoration: none;
    }

    a:hover {
      text-decoration: underline;
      color: #ffee99;
    }

    /* --- Rodapé --- */
    .footer-fc {
      position: fixed;
      bottom: 0;
      left: 0;
      width: 100%;
      background-color: #000;
      color: #ffcc66;
      text-align: center;
      padding: 14px 10px;
      font-family: 'Segoe UI', sans-serif;
      font-size: 14px;
      border-top: 2px solid #ffcc66;
      box-shadow: 0 -2px 8px rgba(0, 0, 0, 0.9);
    }

    .footer-fc span {
      color: #ffdd88;
      font-style: italic;
      animation: brilho-suave 5s ease-in-out infinite;
    }
</style>

