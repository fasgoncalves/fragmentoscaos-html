<script>
  // Extrair apenas o nome da página atual (sem caminho nem extensão)
  const path = window.location.pathname;
  const pagina = path.substring(path.lastIndexOf('/') + 1).replace('.html', '');

  fetch(`https://snd.softelabs.pt/api/visitas/${pagina}`)
    .then(res => res.json())
    .then(data => {
      document.getElementById('visitas').innerText = data.visitas;
    })
    .catch(err => {
      console.error('Erro no contador:', err);
      document.getElementById('visitas').innerText = 'erro';
    });
</script>
