      width: 100%;
      background-color: #000;
      color: #ffcc66;
      text-align: center;
      padding: 14px 10px;
      font-family: 'Segoe UI', sans-serif;
      font-size: 14px;
      border-top: 2px solid #ffcc66;
      box-shadow: 0 -2px 8px rgba(0, 0, 0, 0.9);
    }

    .footer-fc span {
      color: #ffdd88;
      font-style: italic;
      animation: brilho-suave 5s ease-in-out infinite;
    }
</style>

