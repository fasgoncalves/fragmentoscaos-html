      <h1 class="post-title">Os Fofinhos e hipócritas da Geopolítica</h1>
      <p class="meta">Publicado em 2026-03-14 17:19:45</p>
      <figure class="post-thumb"><img src="https://fasgoncalves.github.io/fragmentoscaos-img/imagens/file_00000000dc187243a412d99d4a474378.jpg" alt=""></figure>
      <div class="post-content">
        <div style="background:#0b0b0b; color:#e8eef4; font-family:Georgia, serif; line-height:2.2; padding:10px; text-align:left;">

<div style="display:none;" itemscope itemtype="https://schema.org/NewsArticle">
  <meta itemprop="headline" content="Os Fofinhos da Geopolítica" />
  <meta itemprop="datePublished" content="2026-03-14" />
  <meta itemprop="dateModified" content="2026-03-14" />
  <meta itemprop="description" content="Uma crónica dura sobre a leviandade moral e política de muitos dirigentes europeus perante conflitos existenciais vividos por outros povos." />
  <meta itemprop="author" content="Francisco Gonçalves" />
  <meta itemprop="author" content="Augustus Veritas" />
  <meta itemprop="image" content="http://www.fragmentoscaos.eu/wp-content/uploads/2026/03/file_00000000dc187243a412d99d4a474378.png" />
