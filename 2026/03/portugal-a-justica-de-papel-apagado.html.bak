  <meta itemprop="datePublished" content="2026-03-10" />
  <meta itemprop="dateModified" content="2026-03-10" />
  <meta itemprop="description" content="Uma reflexão crítica sobre o recurso de Manuel Pinho para o Supremo e o retrato de uma justiça portuguesa lenta, burocrática e corrosiva para a confiança democrática." />
  <meta itemprop="author" content="Francisco Gonçalves e Augustus" />
  <meta itemprop="mainEntityOfPage" content="https://www.fragmentoscaos.eu/" />
